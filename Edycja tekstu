#include <iostream>


void HItoLO(char *text){
    while (*text){
        if ('A' <= *text && *text <= 'Z' ){
            *text += ('a' -'A');
        }
        *text++;
    }
};

void LOtoHI(char *text){
    while (*text){
        if ('a' <= *text && *text <= 'z' ){
            *text += ('A' -'a');
        }
        *text++;
    }
}

int sizer(char *text){
    int size;
    while(*text){
        size++;
        text++;

    }
    return size;
}

int main() {
    char text[] = "Ala ma kota";
    printf("%s \n", text);
    printf("%d \n", sizer(text));
    HItoLO(text);
    printf("%s \n", text);
    LOtoHI(text);
    printf("%s \n", text);



}
}

